--- !u!114 &558947826
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 558947824}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: cd60b96a1b283a044ab8cab37033ff2a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  phase1Dialogue:
  - speakerName: "\uC0AC\uB839\uAD00"
    message: "\uC88B\uC544, \uC2E0\uC785 \uD30C\uC77C\uB7FF! \n\uC804\uD22C \uD6C8\uB828\uC7A5\uC5D0
      \uC628 \uAC83\uC744 \uD658\uC601\uD55C\uB2E4."
    portrait: {fileID: 0}
    isLeft: 0
  - speakerName: "\uC0AC\uB839\uAD00"
    message: "\uC55E\uC5D0 \uBCF4\uC774\uB294 \uD6C8\uB828\uC6A9 \uB354\uBBF8\uAC00
      \uD0C4\uB9C9\uC744 \uC3E0 \uAC83\uC774\uB2E4. WASD\uB85C \uC6C0\uC9C1\uC774\uBA74\uC11C
      [Space] \uD0A4\uB97C \uB20C\uB7EC \n\uB300\uC2DC(\uD68C\uD53C)\uB97C 3\uBC88
      \uC2DC\uC804\uD574 \uBCF4\uC544\uB77C!"
    portrait: {fileID: 0}
    isLeft: 0
  - speakerName: "\uC8FC\uC778\uACF5"
    message: "\uAE4C\uC9D3\uAC83 \uD55C \uBC88 \uD574\uBCF4\uC8E0!"
    portrait: {fileID: 0}
    isLeft: 1
  phase2Dialogue:
  - speakerName: "\uC0AC\uB839\uAD00"
    message: "\uD68C\uD53C \uAE30\uB3D9 \uD6C8\uB828 \uD1B5\uACFC! \uC544\uC8FC \uD6CC\uB96D\uD55C
      \uD0C0\uC774\uBC0D\uC774\uC5C8\uB2E4."
    portrait: {fileID: 0}
    isLeft: 0
  - speakerName: "\uC0AC\uB839\uAD00"
    message: "\uC774\uC81C \uBC18\uACA9\uD560 \uCC28\uB840\uB2E4. "
    portrait: {fileID: 0}
    isLeft: 0
  - speakerName: "\uC0AC\uB839\uAD00"
    message: "\uB354\uBBF8 \uBD07 \uC8FC\uBCC0\uC758 \uD30C\uB780\uC0C9 \uD574\uD0B9\uC874(\uC6D0
      \uC601\uC5ED) \uC548\uC73C\uB85C \uB4E4\uC5B4\uAC00\uC11C \uC811\uADFC\uD574\uB77C! "
    portrait: {fileID: 0}
    isLeft: 0
  - speakerName: "\uC8FC\uC778\uACF5"
    message: "\uADF8\uC815\uB3C8 \uAECC\uC774\uC8E0"
    portrait: {fileID: 0}
    isLeft: 1
  phase3Dialogue:
  - speakerName: "\uC0AC\uB839\uAD00"
    message: "\uD6CC\uB96D\uD558\uAC8C \uC644\uC218\uD588\uAD70! "
    portrait: {fileID: 0}
    isLeft: 1
  - speakerName: "\uC8FC\uC778\uACF5"
    message: "\uC774\uC81C \uCD9C\uBC1C\uD560\uAC8C\uC694"
    portrait: {fileID: 0}
    isLeft: 0
  - speakerName: "\uC0AC\uB839\uAD00"
    message: "\uAE30\uCD08 \uD6C8\uB828\uC740 \uC774\uAC83\uC73C\uB85C \uC885\uB8CC\uD55C\uB2E4.
      \uC774\uC81C \uBA54\uC778 \uAE30\uC9C0\uB85C \uBCF5\uADC0\uD558\uC5EC \uCCAB
      \uCD9C\uACA9 \uC900\uBE44\uB97C \uD558\uB3C4\uB85D \uD574\uB77C. \uACE0\uC0DD\uD588\uB2E4!"
    portrait: {fileID: 0}
    isLeft: 1
  dummyBot: {fileID: 1869123875}
  dialogueManager: {fileID: 57166943}
  dashGuideTextObject: {fileID: 238443132}
  lobbySceneName: Hub_Scene
